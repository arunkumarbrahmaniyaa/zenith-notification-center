{
  "name": "zenith-notification-center",
  "version": "0.1.1",
  "description": "Enterprise-grade React notification ecosystem: toasts, inbox, realtime, push, offline queue, and analytics.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public/znc-sw.js"
  ],
  "sideEffects": [
    "dist/style.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/style.css",
    "./service-worker": "./public/znc-sw.js"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.1.4",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^22.1.0",
    "rollup": "^4.45.1",
    "rollup-plugin-postcss": "^4.0.2",
    "semantic-release": "^24.2.9",
    "storybook": "^8.6.14",
    "typescript": "^5.8.3",
    "vite": "^4.5.13",
    "vitest": "^0.34.6"
  },
  "scripts": {
    "build": "npm run clean && rollup -c && tsc -p tsconfig.build.json && npm run build:css-types",
    "build:css-types": "mkdir -p dist/styles && cp src/styles/styles.css dist/styles/styles.css",
    "clean": "rm -rf dist .turbo coverage",
    "dev": "vite",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "npm run build"
  },
  "keywords": [
    "react",
    "notification",
    "notification-center",
    "toast",
    "realtime",
    "typescript",
    "enterprise"
  ],
  "author": "Zenith Logic Labs",
  "license": "MIT"
}
